# Copy to .env and fill in. Never commit .env.
DATABASE_URL=postgresql+psycopg://splitrail:splitrail@db:5432/splitrail
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=splitrail

# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/integrations/strava/callback

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/integrations/spotify/callback

# Claude API
ANTHROPIC_API_KEY=

# FCM (step 7)
FCM_SERVICE_ACCOUNT_JSON_PATH=
